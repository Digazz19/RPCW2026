:Symptom a owl:Class .

:hasDisease a owl:ObjectProperty;
  rdfs:domain :Patient;
  rdfs:range :Disease .

:Treatment a owl:Class .

:receivesTreatment a owl:ObjectProperty;
  rdfs:domain :Patient;
  rdfs:range :Treatment .

:hasSymptom rdfs:domain :Disease;
  rdfs:range :Symptom .

:hasTreatment rdfs:domain :Disease;
  rdfs:range :Treatment .

:exhibitsSymptom rdfs:domain :Patient;
  rdfs:range :Symptom .

:Acne :hasDescription "Acne vulgaris is the formation of comedones, papules, pustules, nodules, and/or cysts as a result of obstruction and inflammation of pilosebaceous units (hair follicles and their accompanying sebaceous gland). Acne develops on the face and upper trunk. It most often affects adolescents.";
  :hasSymptom :Blackheads, :PusFilledPimples, :Scurring, :SkinRash;
  :hasTreatment :AvoidFattySpicyFood, :AvoidTooManyProducts, :BathTwice, :DrinkPlentyOfWater .

:Aids :hasDescription "Acquired immunodeficiency syndrome (AIDS) is a chronic, potentially life-threatening condition caused by the human immunodeficiency virus (HIV). By damaging your immune system, HIV interferes with your body's ability to fight infection and disease.";
  :hasSymptom :ExtraMaritalContacts, :HighFever, :MuscleWasting, :PatchesInThroat;
  :hasTreatment :AvoidOpenCuts, :ConsultDoctor, :FollowUp, :WearPpeIfPossible .

:Alcoholic_Hepatitis :hasDescription "Alcoholic hepatitis is a diseased, inflammatory condition of the liver caused by heavy alcohol consumption over an extended period of time. It's also aggravated by binge drinking and ongoing alcohol use. If you develop this condition, you must stop drinking alcohol";
  :hasSymptom :AbdominalPain, :DistentionOfAbdomen, :FluidOverload, :HistoryOfAlcoholConsumption,
    :SwellingOfStomach, :Vomiting, :YellowishSkin;
  :hasTreatment :ConsultDoctor, :FollowUp, :Medication, :StopAlcoholConsumption .

:Allergy :hasDescription "An allergy is an immune system response to a foreign substance that's not typically harmful to your body.They can include certain foods, pollen, or pet dander. Your immune system's job is to keep you healthy by fighting harmful pathogens.";
  :hasSymptom :Chills, :ContinuousSneezing, :Shivering, :WateringFromEyes;
  :hasTreatment :ApplyCalamine, :CoverAreaWithBandage, :UseIceToCompressItching .

:Arthritis :hasDescription "Arthritis is the swelling and tenderness of one or more of your joints. The main symptoms of arthritis are joint pain and stiffness, which typically worsen with age. The most common types of arthritis are osteoarthritis and rheumatoid arthritis.";
  :hasSymptom :MovementStiffness, :MuscleWeakness, :PainfulWalking, :StiffNeck, :SwellingJoints;
  :hasTreatment :Exercise, :Massage, :TryAcupuncture, :UseHotAndColdTherapy .

:Bronchial_Asthma :hasDescription "Bronchial asthma is a medical condition which causes the airway path of the lungs to swell and narrow. Due to this swelling, the air path produces excess mucus making it hard to breathe, which results in coughing, short breath, and wheezing. The disease is chronic and interferes with daily working.";
  :hasSymptom :HighFever, :Breathlessness, :Cough, :FamilyHistory, :Fatigue, :MucoidSputum;
  :hasTreatment :GetAwayFromTrigger, :SeekHelp, :SwitchToLooseCloothing, :TakeDeepBreaths .

:Cervical_Spondylosis :hasDescription "Cervical spondylosis is a general term for age-related wear and tear affecting the spinal disks in your neck. As the disks dehydrate and shrink, signs of osteoarthritis develop, including bony projections along the edges of bones (bone spurs).";
  :hasSymptom :BackPain, :Dizziness, :LossOfBalance, :NeckPain, :WeaknessInLimbs;
  :hasTreatment :ConsultDoctor, :Exercise, :TakeOtcPainReliver, :UseHeatingPadOrColdPack .

:Chicken_Pox :hasDescription "Chickenpox is a highly contagious disease caused by the varicella-zoster virus (VZV). It can cause an itchy, blister-like rash. The rash first appears on the chest, back, and face, and then spreads over the entire body, causing between 250 and 500 itchy blisters.";
  :hasSymptom :SkinRash, :HighFever, :Fatigue, :Headache, :Itching, :Lethargy, :LossOfAppetite,
    :Malaise, :MildFever, :RedSpotsOverBody, :SwelledLymphNodes;
  :hasTreatment :AvoidPublicPlaces, :ConsumeNeemLeaves, :TakeVaccine, :UseNeemInBathing .

:Chronic_Cholestasis :hasDescription "Chronic cholestatic diseases, whether occurring in infancy, childhood or adulthood, are characterized by defective bile acid transport from the liver to the intestine, which is caused by primary damage to the biliary epithelium in most cases";
  :hasSymptom :AbdominalPain, :Vomiting, :YellowishSkin, :Itching, :LossOfAppetite,
    :Nausea, :YellowingOfEyes;
  :hasTreatment :ConsultDoctor, :AntiItchMedicine, :ColdBaths, :EatHealthy .

:Common_Cold :hasDescription "The common cold is a viral infection of your nose and throat (upper respiratory tract). It's usually harmless, although it might not feel that way. Many types of viruses can cause a common cold.";
  :hasSymptom :HighFever, :Chills, :ContinuousSneezing, :Cough, :Fatigue, :Headache,
    :Malaise, :SwelledLymphNodes, :ChestPain, :Congestion, :LossOfSmell, :MusclePain,
    :Phlegm, :RednessOfEyes, :RunnyNose, :SinusPressure, :ThroatIrritation;
  :hasTreatment :AvoidColdFood, :DrinkVitaminCRichDrinks, :KeepFeverInCheck, :TakeVapour .

:Dengue :hasDescription "an acute infectious disease caused by a flavivirus (species Dengue virus of the genus Flavivirus), transmitted by aedes mosquitoes, and characterized by headache, severe joint pain, and a rash. — called also breakbone fever, dengue fever.";
  :hasSymptom :SkinRash, :HighFever, :Vomiting, :Chills, :Fatigue, :BackPain, :Headache,
    :LossOfAppetite, :Malaise, :RedSpotsOverBody, :Nausea, :MusclePain, :JointPain, :PainBehindTheEyes;
  :hasTreatment :AvoidFattySpicyFood, :DrinkPapayaLeafJuice, :KeepHydrated, :KeepMosquitosAway .

:Diabetes :hasDescription "Diabetes is a disease that occurs when your blood glucose, also called blood sugar, is too high. Blood glucose is your main source of energy and comes from the food you eat. Insulin, a hormone made by the pancreas, helps glucose from food get into your cells to be used for energy.";
  :hasSymptom :Fatigue, :Lethargy, :BlurredAndDistortedVision, :ExcessiveHunger, :FrequentUrination,
    :IncreasedAppetite, :IncreasedThirst, :IrregularSugarLevel, :Obesity, :Polyuria, :Restlessness,
    :WeightLoss;
  :hasTreatment :ConsultDoctor, :FollowUp, :Exercise, :DietModification, :HaveBalancedDiet,
    :InsulinTherapy .

:Dimorphic_Hemmorhoidspiles :hasDescription "Hemorrhoids, also spelled haemorrhoids, are vascular structures in the anal canal. In their ... Other names, Haemorrhoids, piles, hemorrhoidal disease .";
  :hasSymptom :BloodyStool, :Constipation, :IrritationInAnus, :PainDuringBowelMovements,
    :PainInAnalRegion;
  :hasTreatment :AvoidFattySpicyFood, :ConsumeAloveraJuice, :ConsumeWitchHazel, :WarmBathWithEpsomSalt .

:Drug_Reaction :hasDescription "An adverse drug reaction (ADR) is an injury caused by taking medication. ADRs may occur following a single dose or prolonged administration of a drug or result from the combination of two or more drugs.";
  :hasSymptom :SkinRash, :Itching, :BurningMicturition, :SpottingUrination, :StomachPain;
  :hasTreatment :FollowUp, :ConsultNearestHospital, :StopIrritation, :StopTakingDrug .

:Fungal_Infection :hasDescription "In humans, fungal infections occur when an invading fungus takes over an area of the body and is too much for the immune system to handle. Fungi can live in the air, soil, water, and plants. There are also some fungi that live naturally in the human body. Like many microbes, there are helpful fungi and harmful fungi.";
  :hasSymptom :SkinRash, :Itching, :DischromicPatches, :NodalSkinEruptions;
  :hasTreatment :BathTwice, :KeepInfectedAreaDry, :UseCleanCloths, :UseDetolOrNeemInBathingWater .

:Gastroenteritis :hasDescription "Gastroenteritis is an inflammation of the digestive tract, particularly the stomach, and large and small intestines. Viral and bacterial gastroenteritis are intestinal infections associated with symptoms of diarrhea , abdominal cramps, nausea , and vomiting .";
  :hasSymptom :Vomiting, :Dehydration, :Diarrhoea, :SunkenEyes;
  :hasTreatment :Rest, :EaseBackIntoEating, :StopEatingSolidFoodForWhile, :TryTakingSmallSipsOfWater .

:Gerd :hasDescription "Gastroesophageal reflux disease, or GERD, is a digestive disorder that affects the lower esophageal sphincter (LES), the ring of muscle between the esophagus and stomach. Many people, including pregnant women, suffer from heartburn or acid indigestion caused by GERD.";
  :hasSymptom :Vomiting, :Cough, :ChestPain, :StomachPain, :Acidity, :UlcersOnTongue;
  :hasTreatment :AvoidFattySpicyFood, :Exercise, :AvoidLyingDownAfterEating, :MaintainHealthyWeight .

:Heart_Attack :hasDescription "The death of heart muscle due to the loss of blood supply. The loss of blood supply is usually caused by a complete blockage of a coronary artery, one of the arteries that supplies blood to the heart muscle.";
  :hasSymptom :Vomiting, :Breathlessness, :ChestPain, :Sweating;
  :hasTreatment :CallAmbulance, :ChewOrSwallowAsprin, :KeepCalm .

:Hepatitis_A :hasDescription "Hepatitis A is a highly contagious liver infection caused by the hepatitis A virus. The virus is one of several types of hepatitis viruses that cause inflammation and affect your liver's ability to function.";
  :hasSymptom :AbdominalPain, :Vomiting, :YellowishSkin, :LossOfAppetite, :MildFever,
    :Nausea, :YellowingOfEyes, :MusclePain, :JointPain, :Diarrhoea, :DarkUrine;
  :hasTreatment :AvoidFattySpicyFood, :Medication, :ConsultNearestHospital, :WashHandsThrough .

:Hepatitis_B :hasDescription "Hepatitis B is an infection of your liver. It can cause scarring of the organ, liver failure, and cancer. It can be fatal if it isn't treated. It's spread when people come in contact with the blood, open sores, or body fluids of someone who has the hepatitis B virus.";
  :hasSymptom :AbdominalPain, :YellowishSkin, :Fatigue, :Itching, :Lethargy, :LossOfAppetite,
    :Malaise, :YellowingOfEyes, :DarkUrine, :ReceivingBloodTransfusion, :ReceivingUnsterileInjections,
    :YellowUrine;
  :hasTreatment :Medication, :EatHealthy, :ConsultNearestHospital, :Vaccination .

:Hepatitis_C :hasDescription "Inflammation of the liver due to the hepatitis C virus (HCV), which is usually spread via blood transfusion (rare), hemodialysis, and needle sticks. The damage hepatitis C does to the liver can lead to cirrhosis and its complications as well as cancer.";
  :hasSymptom :YellowishSkin, :FamilyHistory, :Fatigue, :LossOfAppetite, :Nausea, :YellowingOfEyes;
  :hasTreatment :Medication, :EatHealthy, :ConsultNearestHospital, :Vaccination .

:Hepatitis_D :hasDescription "Hepatitis D, also known as the hepatitis delta virus, is an infection that causes the liver to become inflamed. This swelling can impair liver function and cause long-term liver problems, including liver scarring and cancer. The condition is caused by the hepatitis D virus (HDV).";
  :hasSymptom :AbdominalPain, :Vomiting, :YellowishSkin, :Fatigue, :LossOfAppetite,
    :Nausea, :YellowingOfEyes, :JointPain, :DarkUrine;
  :hasTreatment :ConsultDoctor, :FollowUp, :Medication, :EatHealthy .

:Hepatitis_E :hasDescription "A rare form of liver inflammation caused by infection with the hepatitis E virus (HEV). It is transmitted via food or drink handled by an infected person or through infected water supplies in areas where fecal matter may get into the water. Hepatitis E does not cause chronic liver disease.";
  :hasSymptom :HighFever, :AbdominalPain, :Vomiting, :YellowishSkin, :Fatigue, :LossOfAppetite,
    :Nausea, :YellowingOfEyes, :JointPain, :DarkUrine, :AcuteLiverFailure, :Coma, :StomachBleeding;
  :hasTreatment :ConsultDoctor, :Medication, :StopAlcoholConsumption, :Rest .

:Hypertension :hasDescription "Hypertension (HTN or HT), also known as high blood pressure (HBP), is a long-term medical condition in which the blood pressure in the arteries is persistently elevated. High blood pressure typically does not cause symptoms.";
  :hasSymptom :Dizziness, :LossOfBalance, :Headache, :ChestPain, :LackOfConcentration;
  :hasTreatment :GetProperSleep, :Meditation, :ReduceStress, :SaltBaths .

:Hyperthyroidism :hasDescription "Hyperthyroidism (overactive thyroid) occurs when your thyroid gland produces too much of the hormone thyroxine. Hyperthyroidism can accelerate your body's metabolism, causing unintentional weight loss and a rapid or irregular heartbeat.";
  :hasSymptom :MuscleWeakness, :Fatigue, :ExcessiveHunger, :Restlessness, :WeightLoss,
    :Diarrhoea, :Sweating, :AbnormalMenstruation, :FastHeartRate, :Irritability, :MoodSwings;
  :hasTreatment :Massage, :EatHealthy, :TakeRadioactiveIodineTreatment, :UseLemonBalm .

:Hypoglycemia :hasDescription " Hypoglycemia is a condition in which your blood sugar (glucose) level is lower than normal. Glucose is your body's main energy source. Hypoglycemia is often related to diabetes treatment. But other drugs and a variety of conditions — many rare — can cause low blood sugar in people who don't have diabetes.";
  :hasSymptom :Vomiting, :Fatigue, :Headache, :Nausea, :BlurredAndDistortedVision, :ExcessiveHunger,
    :Sweating, :Irritability, :Anxiety, :DryingAndTinglingLips, :Palpitations, :SlurredSpeech;
  :hasTreatment :ConsultDoctor, :CheckInPulse, :DrinkSugaryDrinks, :LieDownOnSide .

:Hypothyroidism :hasDescription "Hypothyroidism, also called underactive thyroid or low thyroid, is a disorder of the endocrine system in which the thyroid gland does not produce enough thyroid hormone.";
  :hasSymptom :Fatigue, :Dizziness, :Lethargy, :AbnormalMenstruation, :Irritability,
    :MoodSwings, :BrittleNails, :ColdHandsAndFeets, :Depression, :EnlargedThyroid, :PuffyFaceAndEyes,
    :SwollenExtremeties, :WeightGain;
  :hasTreatment :Exercise, :EatHealthy, :GetProperSleep, :ReduceStress .

:Impetigo :hasDescription "Impetigo (im-puh-TIE-go) is a common and highly contagious skin infection that mainly affects infants and children. Impetigo usually appears as red sores on the face, especially around a child's nose and mouth, and on hands and feet. The sores burst and develop honey-colored crusts.";
  :hasSymptom :SkinRash, :HighFever, :Blister, :RedSoreAroundNose, :YellowCrustOoze;
  :hasTreatment :ConsultDoctor, :RemoveScabsWithWetCompressedCloth, :SoakAffectedAreaInWarmWater,
    :UseAntibiotics .

:Jaundice :hasDescription "Yellow staining of the skin and sclerae (the whites of the eyes) by abnormally high blood levels of the bile pigment bilirubin. The yellowing extends to other tissues and body fluids. Jaundice was once called the \"morbus regius\" (the regal disease) in the belief that only the touch of a king could cure it";
  :hasSymptom :HighFever, :AbdominalPain, :Vomiting, :YellowishSkin, :Fatigue, :Itching,
    :WeightLoss, :DarkUrine;
  :hasTreatment :DrinkPlentyOfWater, :Medication, :ConsumeMilkThistle, :EatFruitsAndHighFiberousFood .

:Malaria :hasDescription "An infectious disease caused by protozoan parasites from the Plasmodium family that can be transmitted by the bite of the Anopheles mosquito or by a contaminated needle or transfusion. Falciparum malaria is the most deadly type.";
  :hasSymptom :HighFever, :Vomiting, :Chills, :Headache, :Nausea, :MusclePain, :Diarrhoea,
    :Sweating;
  :hasTreatment :ConsultNearestHospital, :AvoidNonVegFood, :AvoidOilyFood, :KeepMosquitosOut .

:Migraine :hasDescription "A migraine can cause severe throbbing pain or a pulsing sensation, usually on one side of the head. It's often accompanied by nausea, vomiting, and extreme sensitivity to light and sound. Migraine attacks can last for hours to days, and the pain can be so severe that it interferes with your daily activities.";
  :hasSymptom :StiffNeck, :Headache, :BlurredAndDistortedVision, :ExcessiveHunger, :Acidity,
    :Irritability, :Depression, :Indigestion, :VisualDisturbances;
  :hasTreatment :ConsultDoctor, :Meditation, :ReduceStress, :UsePoloroidGlassesInSun .

:Osteoarthristis :hasDescription "Osteoarthritis is the most common form of arthritis, affecting millions of people worldwide. It occurs when the protective cartilage that cushions the ends of your bones wears down over time.";
  :hasSymptom :PainfulWalking, :SwellingJoints, :NeckPain, :JointPain, :HipJointPain,
    :KneePain;
  :hasTreatment :FollowUp, :ConsultNearestHospital, :SaltBaths, :Acetaminophen .

:Paralysis_Brain_Hemorrhage :hasDescription "Intracerebral hemorrhage (ICH) is when blood suddenly bursts into brain tissue, causing damage to your brain. Symptoms usually appear suddenly during ICH. They include headache, weakness, confusion, and paralysis, particularly on one side of your body.";
  :hasSymptom :Vomiting, :Headache, :AlteredSensorium, :WeaknessOfOneBodySide;
  :hasTreatment :ConsultDoctor, :Exercise, :Massage, :EatHealthy .

:Peptic_Ulcer_Diseae :hasDescription "Peptic ulcer disease (PUD) is a break in the inner lining of the stomach, the first part of the small intestine, or sometimes the lower esophagus. An ulcer in the stomach is called a gastric ulcer, while one in the first part of the intestines is a duodenal ulcer.";
  :hasSymptom :AbdominalPain, :Vomiting, :LossOfAppetite, :Indigestion, :InternalItching,
    :PassageOfGases;
  :hasTreatment :AvoidFattySpicyFood, :ConsumeProbioticFood, :EliminateMilk, :LimitAlcohol .

:Pneumonia :hasDescription "Pneumonia is an infection in one or both lungs. Bacteria, viruses, and fungi cause it. The infection causes inflammation in the air sacs in your lungs, which are called alveoli. The alveoli fill with fluid or pus, making it difficult to breathe.";
  :hasSymptom :HighFever, :Chills, :Breathlessness, :Cough, :Fatigue, :Malaise, :ChestPain,
    :Phlegm, :Sweating, :FastHeartRate, :RustySputum;
  :hasTreatment :ConsultDoctor, :FollowUp, :Medication, :Rest .

:Psoriasis :hasDescription "Psoriasis is a common skin disorder that forms thick, red, bumpy patches covered with silvery scales. They can pop up anywhere, but most appear on the scalp, elbows, knees, and lower back. Psoriasis can't be passed from person to person. It does sometimes happen in members of the same family.";
  :hasSymptom :SkinRash, :JointPain, :InflammatoryNails, :SilverLikeDusting, :SkinPeeling,
    :SmallDentsInNails;
  :hasTreatment :ConsultDoctor, :SaltBaths, :StopBleedingUsingPressure, :WashHandsWithWarmSoapyWater .

:Tuberculosis :hasDescription "Tuberculosis (TB) is an infectious disease usually caused by Mycobacterium tuberculosis (MTB) bacteria. Tuberculosis generally affects the lungs, but can also affect other parts of the body. Most infections show no symptoms, in which case it is known as latent tuberculosis.";
  :hasSymptom :HighFever, :Vomiting, :Chills, :Breathlessness, :Cough, :Fatigue, :LossOfAppetite,
    :Malaise, :MildFever, :SwelledLymphNodes, :YellowingOfEyes, :ChestPain, :Phlegm, :WeightLoss,
    :Sweating, :BloodInSputum;
  :hasTreatment :ConsultDoctor, :Medication, :Rest, :CoverMouth .

:Typhoid :hasDescription "An acute illness characterized by fever caused by infection with the bacterium Salmonella typhi. Typhoid fever has an insidious onset, with fever, headache, constipation, malaise, chills, and muscle pain. Diarrhea is uncommon, and vomiting is not usually severe.";
  :hasSymptom :HighFever, :AbdominalPain, :Vomiting, :Chills, :Fatigue, :Headache, :Nausea,
    :Constipation, :Diarrhoea, :BellyPain, :ToxicLookTyphos;
  :hasTreatment :ConsultDoctor, :Medication, :AntiboiticTherapy, :EatHighCalorieVegitables .

:Urinary_Tract_Infection :hasDescription "Urinary tract infection: An infection of the kidney, ureter, bladder, or urethra. Abbreviated UTI. Not everyone with a UTI has symptoms, but common symptoms include a frequent urge to urinate and pain or burning when urinating.";
  :hasSymptom :BurningMicturition, :BladderDiscomfort, :ContinuousFeelOfUrine, :FoulSmellOfUrine;
  :hasTreatment :DrinkPlentyOfWater, :DrinkCranberryJuice, :IncreaseVitaminCIntake,
    :TakeProbiotics .

:Varicose_Veins :hasDescription "A vein that has enlarged and twisted, often appearing as a bulging, blue blood vessel that is clearly visible through the skin. Varicose veins are most common in older adults, particularly women, and occur especially on the legs.";
  :hasSymptom :Fatigue, :Obesity, :Bruising, :Cramps, :ProminentVeinsOnCalf, :SwollenBloodVessels,
    :SwollenLegs;
  :hasTreatment :DontStandStillForLong, :LieDownFlatAndRaiseTheLegHigh, :UseOinments,
    :UseVeinCompression .

:Vertigo_Paroymsal_Positional_Vertigo :hasDescription "Benign paroxysmal positional vertigo (BPPV) is one of the most common causes of vertigo — the sudden sensation that you're spinning or that the inside of your head is spinning. Benign paroxysmal positional vertigo causes brief episodes of mild to intense dizziness.";
  :hasSymptom :Vomiting, :LossOfBalance, :Headache, :Nausea, :SpinningMovements, :Unsteadiness;
  :hasTreatment :AvoidAbruptHeadMovment, :AvoidSuddenChangeInBody, :LieDown, :Relax .

:Flu :hasSymptom :Cough, :Fever, :SoreThroat;
  :hasTreatment :AntiviralDrugs, :Hydration, :Rest .

